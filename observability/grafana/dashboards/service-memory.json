{
  "title": "APEX — Service Memory",
  "uid": "apex-service-memory",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Per-container memory (working set)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(25, container_memory_working_set_bytes{name!=\"\"})",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Per-container memory as % of its limit (only where a limit is set)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * container_memory_working_set_bytes{name!=\"\"} / (container_spec_memory_limit_bytes{name!=\"\"} > 0)",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Host = GPU memory used % (128 GB unified pool, shared)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "host mem used %"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GPU utilization — compute & memory bandwidth (DCGM, %)",
      "description": "GB10 has unified memory, so there is no separate GPU framebuffer to chart. These two utilization signals are the actionable GPU metrics: compute % shows whether the SMs are saturated (the relevant ceiling for inference); memory-bandwidth % shows whether the GPU is bandwidth-bound moving weights/KV cache. For memory *capacity* used, see the Host=GPU memory panel — it is the same pool.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "compute util (GPU {{gpu}})"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "DCGM_FI_DEV_MEM_COPY_UTIL",
          "legendFormat": "memory bandwidth util (GPU {{gpu}})"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "GPU temperature (DCGM, °C)",
      "description": "Throttling kicks in around 85-87°C. Sustained 80+°C under load is the early-warning sign.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "celsius" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "DCGM_FI_DEV_GPU_TEMP",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "GPU power draw (DCGM, W)",
      "description": "Proxy for actual workload intensity — flatlining at TDP means the GPU is doing as much work as it can.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "watt" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "DCGM_FI_DEV_POWER_USAGE",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    }
  ]
}
