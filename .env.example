# ── apex-spark-01 service stack ───────────────────────────────────────────
# Copy to .env and fill in. Lock down with `chmod 600 .env` after editing.
# Only if you'll back .env off-box (git, shared store): sops-encrypt to .env.enc;
# see SETUP.md A8 for the binary-mode recipe. The default posture for this box
# (single-tenant, VPN-only) is just chmod 600 + SED firmware lock — sops is optional.

# ── Postgres ──
PG_USER=apex
PG_PW=change-me-strong
PG_DB=apex

# ── MinIO (S3-compatible object store) ──
MINIO_ROOT_USER=apex-admin
MINIO_ROOT_PASSWORD=change-me-strong

# ── HuggingFace ──
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ── Inference: vLLM ──
# vLLM gets 75% of the inference pool. 0.65 of the FULL 128GB pool ≈ 84GB.
# Start vLLM FIRST so it stakes its slice before Ollama loads.
#
# VLLM_MODEL accepts three forms (auto-detected by the resolver in
# compose.inference.yml):
#   bare name  — e.g. Qwen3-32B-AWQ           — loads /data/local/Qwen3-32B-AWQ
#                                                 (preferred; what hf-curl-download.sh
#                                                  drops models into)
#   abs path   — e.g. /data/local/Qwen3-32B-AWQ — loaded as-is (legacy form)
#   HF repo ID — e.g. Qwen/Qwen3-32B-AWQ      — looked up in /data/hf-cache
#                                                 (needs full HF cache layout)
# The bundle exposes the model on the OpenAI API under a clean short name:
# the basename for paths, the full repo ID for HF lookups. So API clients
# should use `"model": "Qwen3-32B-AWQ"` regardless of which form is set here.
VLLM_MODEL=Qwen3-32B-AWQ
VLLM_GPU_UTIL=0.65
VLLM_MAX_LEN=16384

# Reasoning-content separation for "thinking" models (Qwen3, DeepSeek-R1, ...).
# When set, vLLM routes <think>...</think> tokens into a separate
# choices[].message.reasoning_content field, so OpenAI-compatible clients
# (NORA, SIRA, Open-WebUI) only see the clean final answer in message.content
# without the model's internal reasoning trace leaking through.
#   qwen3         — Qwen3-* models (recommended for our default VLLM_MODEL)
#   deepseek_r1   — DeepSeek-R1; also works for Qwen3 (same <think> delimiter)
#                   on older vLLM builds that don't recognize 'qwen3'
# Leave BLANK for non-reasoning models — the flags will be omitted entirely
# (some models reject --enable-reasoning).
VLLM_REASONING_PARSER=qwen3

# ── Inference: TEI embeddings ──
# TEI_MODEL and TEI_RERANKER_MODEL both accept three forms (same resolver
# as VLLM_MODEL):
#   bare name (preferred)  — bge-m3                  → /data/local/bge-m3
#   absolute path          — /data/local/bge-m3
#   HF repo ID             — BAAI/bge-m3             (HF cache lookup)
TEI_MODEL=bge-m3
TEI_RERANKER_MODEL=jina-reranker-v2-base-multilingual
# Pulled via: ./hf-curl-download.sh jinaai/jina-reranker-v2-base-multilingual
# Why this and not BAAI/bge-reranker-v2-m3: TEI's CPU/arm64 build uses the ORT
# (ONNX Runtime) backend, which requires onnx/model.onnx in the model dir.
# BAAI/bge-reranker-v2-m3 ships only PyTorch safetensors — no ONNX export —
# so TEI fails to start with "File at '.../onnx/model.onnx' does not exist".
# jinaai/jina-reranker-v2-base-multilingual ships ONNX, similar multilingual
# quality, smaller (278M vs 568M). To use bge-reranker-v2-m3 you must either
# convert it to ONNX yourself (optimum-cli export onnx) or rebuild TEI with
# the candle backend feature.
# TEI must be built from source on this box (no arm64 prebuilt exists).
# Default is CPU build; override to local/tei:gb10 for GPU build.
# See SETUP.md B2-build. The same image serves both embedder and reranker
# (TEI auto-detects cross-encoder models and exposes /rerank instead of /embed).
TEI_IMAGE=local/tei:cpu-arm64

# ── Observability (Grafana at https://$SITE_HOST/grafana) ──
GRAFANA_PASSWORD=change-me-strong

# ── Gateway ──
# Primary hostname — used by open-webui's WEBUI_URL (single value, no commas).
SITE_HOST=apex-spark-01.local

# Caddy's site addresses (comma-separated allowed). Defaults to SITE_HOST if
# unset/blank. **Always use hostnames here — never IPs.** Caddy's Go TLS stack
# has an IP-SNI issue: clients connecting to https://<ip>/ get TLS internal_error.
# For multi-machine access, distribute the hostname via DNS / mDNS / /etc/hosts
# instead. See README "Reaching the stack from other machines".
SITE_ADDRESSES=apex-spark-01.local

# ── Auth ──
# Gateway is currently UNAUTHENTICATED — relies on VPN/network restrictions.
# To re-enable IdP auth: restore oauth2-proxy in compose.gateway.yml + Caddyfile
# (see git history), then uncomment and fill these:
#
# OIDC_ISSUER_URL=https://login.microsoftonline.com/<tenant-id>/v2.0
# OIDC_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# OIDC_CLIENT_SECRET=change-me
# OAUTH2_EMAIL_DOMAINS=<corp-domain>
# OAUTH2_COOKIE_SECRET=$(openssl rand -base64 32)
# HTTP_PROXY=    HTTPS_PROXY=    NO_PROXY=localhost,127.0.0.1,::1

# ── Backups (make backup) ──
BACKUP_DIR=/data/srv/backups
LOCAL_KEEP_DAYS=7
# Off-box DR target. LEAVE BLANK for now — backups stage locally only until set.
# Examples:  sftp:backup@nas.<corp>:/apex-spark   |   s3:https://minio.<corp>/apex
RESTIC_REPO=
RESTIC_PASSWORD=
# restic retention (used when RESTIC_REPO is set)
KEEP_DAILY=14
KEEP_WEEKLY=8
KEEP_MONTHLY=6
