# ── apex-spark-01 service stack ───────────────────────────────────────────
# Copy to .env and fill in. Lock down with `chmod 600 .env` after editing.
# Only if you'll back .env off-box (git, shared store): sops-encrypt to .env.enc;
# see SETUP.md A8 for the binary-mode recipe. The default posture for this box
# (single-tenant, VPN-only) is just chmod 600 + SED firmware lock — sops is optional.

# ── Postgres ──
PG_USER=apex
PG_PW=change-me-strong
PG_DB=apex

# ── MinIO (S3-compatible object store) ──
MINIO_ROOT_USER=apex-admin
MINIO_ROOT_PASSWORD=change-me-strong

# ── HuggingFace ──
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ── Inference: vLLM ──
# vLLM gets 75% of the inference pool. 0.65 of the FULL 128GB pool ≈ 84GB.
# Start vLLM FIRST so it stakes its slice before Ollama loads.
#
# VLLM_MODEL accepts three forms (auto-detected by the resolver in
# compose.inference.yml):
#   bare name  — e.g. Qwen3-32B-AWQ           — loads /data/local/Qwen3-32B-AWQ
#                                                 (preferred; what hf-curl-download.sh
#                                                  drops models into)
#   abs path   — e.g. /data/local/Qwen3-32B-AWQ — loaded as-is (legacy form)
#   HF repo ID — e.g. Qwen/Qwen3-32B-AWQ      — looked up in /data/hf-cache
#                                                 (needs full HF cache layout)
# The bundle exposes the model on the OpenAI API under a clean short name:
# the basename for paths, the full repo ID for HF lookups. So API clients
# should use `"model": "Qwen3-32B-AWQ"` regardless of which form is set here.
VLLM_MODEL=Qwen3-32B-AWQ
# Memory split (128 GB unified pool):
#   0.58 — original setting; reserves ~8 GB for two GPU TEI services + Ollama
#          headroom. Right for 16K-32K context.
#   0.65 — bumped to feed KV cache for 128K YaRN context (see VLLM_ROPE_SCALING
#          below). At 128K, one full-context sequence = ~32 GB KV; 0.65 leaves
#          ~63 GB after AWQ weights ⇒ ~2 concurrent full-context requests, plus
#          many shorter ones (PagedAttention allocates KV on-demand per token).
# WARNING at 0.65: if Ollama is actively serving a model (~28 GB) AT THE SAME
# TIME as a 128K vLLM request, you may approach pool exhaustion. Either keep
# Ollama unloaded (OLLAMA_KEEP_ALIVE expires after 30m idle) or drop back to 0.60.
VLLM_GPU_UTIL=0.65
# Qwen3-32B native context is 32768; with YaRN scaling (VLLM_ROPE_SCALING below)
# it extends to 131072. Lower this if KV-cache pressure causes OOM at runtime.
VLLM_MAX_LEN=131072
# Long-context (YaRN) rope scaling. Required when VLLM_MAX_LEN > the model's
# native context (Qwen3-32B native = 32768; max with YaRN = 131072, factor 4).
# Leave BLANK to disable — YaRN noticeably degrades quality on short prompts
# (Qwen team's own recommendation: only enable when you actually need >32K).
# Other models: set per their HF model-card recipe, or leave blank.
# vLLM passes this string verbatim to --rope-scaling; keep it valid JSON with
# NO spaces (compose passes it through bash word-splitting).
VLLM_ROPE_SCALING={"rope_type":"yarn","factor":4.0,"original_max_position_embeddings":32768}

# Reasoning-content separation for "thinking" models (Qwen3, DeepSeek-R1, ...).
# When set, vLLM routes <think>...</think> tokens into a separate
# choices[].message.reasoning_content field, so OpenAI-compatible clients
# (NORA, SIRA, Open-WebUI) only see the clean final answer in message.content
# without the model's internal reasoning trace leaking through.
#   qwen3         — Qwen3-* models (recommended for our default VLLM_MODEL)
#   deepseek_r1   — DeepSeek-R1; also works for Qwen3 (same <think> delimiter)
#                   on older vLLM builds that don't recognize 'qwen3'
# Leave BLANK for non-reasoning models — the flags will be omitted entirely
# (some models reject --enable-reasoning).
VLLM_REASONING_PARSER=qwen3

# ── Inference: vLLM Vision-Language (VL) — mutually exclusive with text vllm ──
# Owned by model-switch (compose.switch.yml). Never runs simultaneously with
# the text vllm above — model-switch stops one before starting the other.
# Started on demand when an /v1 client requests VL_MODEL_NAME.
#
# TEXT_MODEL_NAME must equal what the text vllm advertises via --served-model-name;
# with the default bare-name resolver that's the basename (Qwen3-32B-AWQ) or
# the HF repo ID. Duplicated here so model-switch knows which slot to route to.
TEXT_MODEL_NAME=Qwen3-32B-AWQ
# VL_MODEL accepts the same three forms as VLLM_MODEL (bare / abs / HF repo).
# Start with Qwen3-VL-8B-Instruct (fp16, ~16 GB) to validate the pipeline;
# upgrade to Qwen/Qwen3-VL-32B-Instruct-FP8 (~32 GB) once you know it works.
# Third-party AWQ variants of Qwen3-VL do exist but Qwen's official FP8
# quants avoid the compatibility risk of a random AWQ checkpoint.
VL_MODEL=Qwen/Qwen3-VL-8B-Instruct
# VL_MODEL_NAME must equal the basename or HF repo ID that vLLM will use as
# --served-model-name (see the vllm-vl service resolver in compose.inference.yml).
# For bare-name / abs-path forms this is the basename; for HF repo forms this
# is the basename of the last path segment. Double-check against the vllm-vl
# startup log line: "vLLM-VL loading: ... (API model name: <THIS>)".
VL_MODEL_NAME=Qwen3-VL-8B-Instruct
# Memory slice when VL is active. Text vllm is stopped, so VL can be greedy:
#   0.35 — 8B fp16 (~16 GB weights + generous KV headroom)
#   0.55 — 32B FP8 (~32 GB weights)
VL_GPU_UTIL=0.35
# Max context for VL. Diagram-to-code prompts rarely need more than 32K
# (image tokens dominate). Bump if you're stitching many pages at once.
VL_MAX_LEN=32768
# Max images per prompt (multi-page sequence-flow diagrams). vLLM enforces
# this; requests with more images are rejected. Bump if your diagrams span
# more pages.
VL_MAX_IMAGES=6

# ── Inference: TEI embeddings ──
# TEI_MODEL and TEI_RERANKER_MODEL both accept three forms (same resolver
# as VLLM_MODEL):
#   bare name (preferred)  — bge-m3                  → /data/local/bge-m3
#   absolute path          — /data/local/bge-m3
#   HF repo ID             — BAAI/bge-m3             (HF cache lookup)
TEI_MODEL=bge-m3
TEI_RERANKER_MODEL=bge-reranker-large
# Pulled via: ./hf-curl-download.sh BAAI/bge-reranker-large
# Picking a reranker for TEI (CPU or GPU build) means clearing TWO hurdles:
#   1. ONNX export available on HF — TEI's ORT backend (CPU) and Candle
#      backend (GPU) both prefer ONNX; safetensors-only models can fail.
#   2. `model_type` field present in config.json — TEI's config parser is
#      strict and does NOT follow auto_map (the trust_remote_code=True path).
# bge-reranker-large clears both (model_type=xlm-roberta, ships ONNX).
# Cautionary tales we hit during selection:
#   - BAAI/bge-reranker-v2-m3 — ships PyTorch safetensors only, no ONNX export
#     ⇒ TEI fails: "File at '.../onnx/model.onnx' does not exist".
#   - jinaai/jina-reranker-v2-base-multilingual — ships ONNX but its config
#     uses auto_map + custom XLMRobertaFlashConfig code, with no bare
#     `model_type` field ⇒ TEI fails: "missing field 'model_type'".
# To use either anyway: convert/patch yourself (optimum-cli export onnx, or
# add `"model_type": "xlm-roberta"` to config.json) — fragile, gets clobbered
# on re-download. Easier to pick a model that ships both correctly.
# Other ONNX+model_type ready alternatives (verified):
#   BAAI/bge-reranker-base                 (~278M, xlm-roberta, smaller/faster)
#   mixedbread-ai/mxbai-rerank-large-v1    (~435M, deberta-v2, strong English)
#   mixedbread-ai/mxbai-rerank-base-v1     (~184M, deberta-v2)
# TEI must be built from source on this box (no arm64 prebuilt exists).
# Default is the GB10/sm_121 GPU build (~5-15ms/embedding, ~4 GB GPU mem per
# instance — embedder + reranker = ~8 GB total, accounted for by VLLM_GPU_UTIL
# above). To fall back to CPU/arm64: set TEI_IMAGE=local/tei:cpu-arm64, drop
# the deploy.devices blocks in compose.inference.yml, and bump VLLM_GPU_UTIL
# back to 0.65. See SETUP.md B2-build. The same image serves both embedder
# and reranker (TEI auto-detects cross-encoder models and exposes /rerank
# instead of /embed).
TEI_IMAGE=local/tei:gb10

# ── Observability (Grafana at http://$SITE_HOST/grafana/) ──
GRAFANA_PASSWORD=change-me-strong

# ── Gateway ──
# Primary hostname — used by open-webui's WEBUI_URL (single value, no commas).
SITE_HOST=apex-spark-01.local

# Caddy's site addresses (comma-separated allowed). Defaults to SITE_HOST if
# unset/blank. **Always use hostnames here — never IPs.** Caddy's Go TLS stack
# has an IP-SNI issue: clients connecting to https://<ip>/ get TLS internal_error.
# For multi-machine access, distribute the hostname via DNS / mDNS / /etc/hosts
# instead. See README "Reaching the stack from other machines".
SITE_ADDRESSES=apex-spark-01.local

# ── Auth ──
# Gateway is currently UNAUTHENTICATED — relies on VPN/network restrictions.
# To re-enable IdP auth: restore oauth2-proxy in compose.gateway.yml + Caddyfile
# (see git history), then uncomment and fill these:
#
# OIDC_ISSUER_URL=https://login.microsoftonline.com/<tenant-id>/v2.0
# OIDC_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# OIDC_CLIENT_SECRET=change-me
# OAUTH2_EMAIL_DOMAINS=<corp-domain>
# OAUTH2_COOKIE_SECRET=$(openssl rand -base64 32)
# HTTP_PROXY=    HTTPS_PROXY=    NO_PROXY=localhost,127.0.0.1,::1

# ── Backups (make backup) ──
BACKUP_DIR=/data/srv/backups
LOCAL_KEEP_DAYS=7
# Off-box DR target. LEAVE BLANK for now — backups stage locally only until set.
# Examples:  sftp:backup@nas.<corp>:/apex-spark   |   s3:https://minio.<corp>/apex
RESTIC_REPO=
RESTIC_PASSWORD=
# restic retention (used when RESTIC_REPO is set)
KEEP_DAILY=14
KEEP_WEEKLY=8
KEEP_MONTHLY=6
