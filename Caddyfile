# Single TLS entrypoint — NO gateway auth (relies on VPN/network restrictions).
# `tls internal` issues a self-signed cert from Caddy's internal CA — fine for a
# VPN-only box. For corp PKI, replace with:
#   tls /etc/caddy/cert.pem /etc/caddy/key.pem
#
# If you ever need auth back, see git history for the oauth2-proxy version, or
# add `basicauth` blocks per route, or restore forward_auth to an auth proxy.

{$SITE_ADDRESSES} {
	# Single comma-separated list — Caddy parses it as multiple site addresses
	# and issues one cert from its internal CA with all of them in the SAN list.
	# Default (in .env.example): SITE_ADDRESSES=${SITE_HOST}  (hostname only)
	# Multi-access: SITE_ADDRESSES=apex-spark-01.local, 10.x.x.x  (hostname + IP)
	# Note: WEBUI_URL in compose.apps.yml still uses SITE_HOST (single value).
	tls internal

	# OpenAI-compatible LLM API (vLLM) — /v1 path preserved.
	handle /v1/* {
		reverse_proxy vllm:8000
	}

	# Embeddings (TEI) — prefix stripped.
	handle_path /embed/* {
		reverse_proxy tei:80
	}

	# Ollama API — prefix stripped.
	handle_path /ollama/* {
		reverse_proxy ollama:11434
	}

	# open-webui — browser chat UI for vLLM (prefix preserved; webui serves at /chat sub-path).
	handle /chat/* {
		reverse_proxy open-webui:8080
	}

	# Additional APEX application(s) — add routes here as you add services to compose.apps.yml.
	# handle_path /apex/* {
	# 	reverse_proxy my-app:8080
	# }

	# Grafana — prefix preserved (Grafana serves from /grafana sub-path).
	handle /grafana/* {
		reverse_proxy grafana:3000
	}

	# default
	respond "apex-spark-01 gateway" 200
}
