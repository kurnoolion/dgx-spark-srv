# HTTP-only — VPN/network-restricted box, NO gateway auth.
# For HTTPS (tls internal + SITE_ADDRESSES site block), see git history.
# For auth, see git history for the oauth2-proxy version, or add `basicauth`
# blocks per route, or restore forward_auth to an auth proxy.
#
# `:80` matches any Host header on port 80, so http://localhost,
# http://apex-spark-01.local, and http://<ip> all route here.

:80 {
	# OpenAI-compatible LLM API — routed via model-switch (compose.switch.yml),
	# NOT directly to a vllm backend. model-switch owns vllm-text/vllm-vl
	# lifecycle: only one vllm runs at a time; a request with a different
	# `model` field triggers a swap (or gets 409 if the other model is busy).
	# Both text and VL models appear in /v1/models regardless of which is loaded.
	handle /v1/* {
		reverse_proxy model-switch:9000
	}

	# TEI listens at bare /embed and /rerank, so we match both the bare path
	# and any subpaths, and use `handle` (preserve prefix). `handle` shorthand
	# only takes ONE path, so use named matchers for the multi-path case.
	@tei_embed   path /embed /embed/*
	@tei_rerank  path /rerank /rerank/*

	# Embeddings (TEI).
	handle @tei_embed {
		reverse_proxy tei:80
	}

	# Reranking (second TEI instance, cross-encoder model).
	handle @tei_rerank {
		reverse_proxy tei-reranker:80
	}

	# Ollama API — prefix stripped.
	handle_path /ollama/* {
		reverse_proxy ollama:11434
	}

	# Grafana — prefix preserved (Grafana serves from /grafana sub-path).
	redir /grafana /grafana/ 308
	handle /grafana/* {
		reverse_proxy grafana:3000
	}

	# Status dashboard — static HTML written by on-box scripts (e.g. the
	# vllm-watch-load loop) into host path /data/srv/status/, which is
	# mounted into the caddy container at /srv/static/status (see
	# compose.gateway.yml).
	redir /health-status /health-status/ 308
	handle_path /health-status/* {
		root * /srv/static/status
		file_server
	}

	# Additional APEX application(s) — add routes here as you add services to compose.apps.yml.
	# handle_path /apex/* {
	# 	reverse_proxy my-app:8080
	# }

	# open-webui at ROOT — its assets hard-code /static/ and /assets/ paths that
	# don't survive sub-path serving, so it must be at /. Everything above this
	# (handle/handle_path) is matched first by Caddy; only unmatched requests
	# (including /, /static/*, /assets/*, /_app/*, /api/*, the SPA itself) hit
	# open-webui. The old /chat URL redirects here for backward-compat.
	redir /chat / 301
	redir /chat/ / 301
	reverse_proxy open-webui:8080
}
