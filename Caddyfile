# HTTP-only — VPN/network-restricted box, NO gateway auth.
# For HTTPS (tls internal + SITE_ADDRESSES site block), see git history.
# For auth, see git history for the oauth2-proxy version, or add `basicauth`
# blocks per route, or restore forward_auth to an auth proxy.
#
# `:80` matches any Host header on port 80, so http://localhost,
# http://apex-spark-01.local, and http://<ip> all route here.

:80 {
	# OpenAI-compatible LLM API (vLLM) — /v1 path preserved.
	handle /v1/* {
		reverse_proxy vllm:8000
	}

	# Embeddings (TEI) — prefix preserved; TEI listens at bare /embed.
	# Match both bare /embed and /embed/* so a POST /embed isn't a 404.
	handle /embed /embed/* {
		reverse_proxy tei:80
	}

	# Reranking (second TEI instance, cross-encoder model) — same as /embed:
	# TEI's /rerank is a bare-path endpoint; preserve prefix and match the bare path.
	handle /rerank /rerank/* {
		reverse_proxy tei-reranker:80
	}

	# Ollama API — prefix stripped.
	handle_path /ollama/* {
		reverse_proxy ollama:11434
	}

	# Grafana — prefix preserved (Grafana serves from /grafana sub-path).
	redir /grafana /grafana/ 308
	handle /grafana/* {
		reverse_proxy grafana:3000
	}

	# Additional APEX application(s) — add routes here as you add services to compose.apps.yml.
	# handle_path /apex/* {
	# 	reverse_proxy my-app:8080
	# }

	# open-webui at ROOT — its assets hard-code /static/ and /assets/ paths that
	# don't survive sub-path serving, so it must be at /. Everything above this
	# (handle/handle_path) is matched first by Caddy; only unmatched requests
	# (including /, /static/*, /assets/*, /_app/*, /api/*, the SPA itself) hit
	# open-webui. The old /chat URL redirects here for backward-compat.
	redir /chat / 301
	redir /chat/ / 301
	reverse_proxy open-webui:8080
}
